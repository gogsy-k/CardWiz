# RewardXtra backend — env config
# Is file ko copy karke ".env" banao aur asli values daalo.
# .env git mein commit NAHI hota (.gitignore mein hai). Secrets safe rakho.

# Server kis port pe chale
PORT=3000

# Google OAuth Client ID (Web application type).
# Google Cloud Console > APIs & Services > Credentials se milega.
# Ye PUBLIC value hai (extension code mein bhi yahi daalna hai) — secret nahi.
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com

# JWT signing secret — humare apne session tokens sign karne ke liye.
# Koi bhi lamba random string. YE SECRET HAI — kabhi commit/share mat karo.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Session token kitne din valid rahe
JWT_EXPIRES_IN=30d

# Database (OPTIONAL).
# Khaali chhodoge to JSON-file store use hoga (backend/data/users.json) — zero setup,
# turant chal jaata hai. Production ke liye Supabase/Postgres ka connection string daalo:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# Extension ID(s) jinhe CORS allow karna hai (comma-separated).
# Khaali = dev mein sabhi chrome-extension:// origins allow (sirf development ke liye).
# Production mein apni published extension ID daalo:
# ALLOWED_EXTENSION_IDS=abcdefghijklmnopabcdefghijklmnop
ALLOWED_EXTENSION_IDS=
