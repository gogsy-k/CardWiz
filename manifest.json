{
  "manifest_version": 3,
  "name": "CardWiz — Best Card & Bill Reminders",
  "version": "1.0",
  "description": "Checkout pe sabse zyada bachat dene wala card bataye + bill due-date reminders. Privacy-first, India-first. | cardwiz.in",
  "author": "CardWiz",
  "homepage_url": "https://github.com/",
  "action": {
    "default_popup": "popup-smartcard.html",
    "default_title": "CardWiz — best card batao",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["storage", "alarms", "notifications", "identity"],
  "host_permissions": [
    "https://cardwiz-backend.onrender.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.in/*",
        "*://*.flipkart.com/*",
        "*://*.myntra.com/*",
        "*://*.swiggy.com/*",
        "*://*.zomato.com/*",
        "*://*.bigbasket.com/*",
        "*://*.blinkit.com/*",
        "*://*.zeptonow.com/*",
        "*://*.nykaa.com/*",
        "*://*.ajio.com/*",
        "*://*.meesho.com/*",
        "*://*.tatacliq.com/*",
        "*://*.makemytrip.com/*",
        "*://*.cleartrip.com/*",
        "*://*.irctc.co.in/*",
        "*://*.bookmyshow.com/*"
      ],
      "js": ["recommend.js", "offers.js", "captracker.js", "affiliate.js", "catalog.js", "content-detect.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["data/cards.json"],
      "matches": [
        "*://*.amazon.in/*",
        "*://*.flipkart.com/*",
        "*://*.myntra.com/*",
        "*://*.swiggy.com/*",
        "*://*.zomato.com/*",
        "*://*.bigbasket.com/*",
        "*://*.blinkit.com/*",
        "*://*.zeptonow.com/*",
        "*://*.nykaa.com/*",
        "*://*.ajio.com/*",
        "*://*.meesho.com/*",
        "*://*.tatacliq.com/*",
        "*://*.makemytrip.com/*",
        "*://*.cleartrip.com/*",
        "*://*.irctc.co.in/*",
        "*://*.bookmyshow.com/*"
      ]
    }
  ]
}
